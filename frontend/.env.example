# Local development: uses Vite proxy (routes /api → http://localhost:8000)
VITE_API_URL=/api

# Production (Vercel): set this to your actual deployed GCP backend URL
# VITE_API_URL=https://algosphere-backend-727855659345.us-central1.run.app/api

# Firebase (from Firebase Console → Project Settings → Your apps → Config)
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
