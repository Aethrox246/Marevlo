# Development Environment Variables
# Copy this to .env for local development

DATABASE_URL=postgresql://algosphere:strongpassword@postgres:5432/algosphere_db
REDIS_URL=redis://redis:6379/0
JWT_SECRET=dev-secret-change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
IDE_API_URL=http://localhost:4000

# For development, OTPs will be printed to console
# Uncomment and fill these to enable actual SMTP email sending:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@algosphere.com
# SMTP_USE_TLS=true
