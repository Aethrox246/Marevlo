# Database Configuration
DATABASE_URL=postgresql://algosphere:strongpassword@postgres:5432/algosphere_db

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# IDE Services
IDE_API_URL=http://ide-api:4000

# Email Configuration (SMTP)
# Gmail example (requires App Password, not regular password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@yourdomain.com

# Office 365 / Outlook example:
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=your-email@outlook.com
# SMTP_PASS=your-password
# SMTP_FROM=noreply@yourdomain.com

# College/Corporate domain example (like .iiitdmj.ac.in):
# SMTP_HOST=mail.iiitdmj.ac.in
# SMTP_PORT=587
# SMTP_USER=your-email@iiitdmj.ac.in
# SMTP_PASS=your-password
# SMTP_FROM=noreply@iiitdmj.ac.in

# Generic SMTP (change these):
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@algosphere.local
SMTP_USE_TLS=true
